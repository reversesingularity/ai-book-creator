# Obsidian Local REST API key (required for obsidian-lore MCP)
# Copy this file to .env and paste your key from Obsidian → Settings → Local REST API
#
# Format: 64-character hexadecimal string (0-9, a-f). Example length only:
#   OBSIDIAN_API_KEY=abcdef0123456789abcdef0123456789abcdef0123456789abcdef0123456789
#
# Do NOT include "Bearer" — the MCP server adds that to HTTP headers automatically.
OBSIDIAN_API_KEY=

# Optional overrides (defaults are set in .cursor/mcp.json):
# OBSIDIAN_BASE_URL=https://127.0.0.1:27124
# OBSIDIAN_VERIFY_SSL=false